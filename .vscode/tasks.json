{
    "version": "2.0.0",
    "tasks": [

        // ── Configure ────────────────────────────────────────────────────────
        {
            "label": "Configure: Debug",
            "type": "shell",
            "osx":    { "command": "cmake", "args": ["--preset", "macos-debug-qt"] },
            "linux":  { "command": "cmake", "args": ["--preset", "linux-debug-qt"] },
            "windows": {
                "command": "cmake",
                "args": ["--preset", "windows-msys-debug-qt"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Configure: Release",
            "type": "shell",
            "osx":    { "command": "cmake", "args": ["--preset", "macos-release-qt"] },
            "linux":  { "command": "cmake", "args": ["--preset", "linux-release-qt"] },
            "windows": {
                "command": "cmake",
                "args": ["--preset", "windows-msys-release-qt"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Configure: Checks (clang-tidy + cppcheck, no sanitizer)",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--preset", "macos-checks-qt"] },
            "linux": { "command": "cmake", "args": ["--preset", "linux-checks-qt"] },
            "windows": { "command": "echo", "args": ["Checks preset not supported on Windows"] },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Build ────────────────────────────────────────────────────────────
        {
            "label": "Build: Debug",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-debug-build-qt"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-debug-build-qt"] },
            "windows": {
                "command": "cmake",
                "args": ["--build", "--preset", "windows-msys-debug-qt-build"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "dependsOn": ["Configure: Debug"],
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Build: Release",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-release-build-qt"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-release-build-qt"] },
            "windows": {
                "command": "cmake",
                "args": ["--build", "--preset", "windows-msys-release-qt-build"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "dependsOn": ["Configure: Release"],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Build: ASan",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-asan-build-qt"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-asan-build-qt"] },
            "windows": { "command": "echo", "args": ["ASan not supported on Windows"] },
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Build: Checks",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-checks-build-qt"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-checks-build-qt"] },
            "windows": { "command": "echo", "args": ["Checks preset not supported on Windows"] },
            "dependsOn": ["Configure: Checks (clang-tidy + cppcheck, no sanitizer)"],
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Test ─────────────────────────────────────────────────────────────
        {
            "label": "Test: Debug",
            "type": "shell",
            "osx":   { "command": "ctest", "args": ["--preset", "macos-debug-test-qt"] },
            "linux": { "command": "ctest", "args": ["--preset", "linux-debug-test-qt"] },
            "windows": {
                "command": "ctest",
                "args": ["--preset", "windows-msys-debug-qt-test"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "dependsOn": ["Build: Debug"],
            "group": { "kind": "test", "isDefault": true },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Test: Release",
            "type": "shell",
            "osx":   { "command": "ctest", "args": ["--preset", "macos-release-test-qt"] },
            "linux": { "command": "ctest", "args": ["--preset", "linux-release-test-qt"] },
            "windows": {
                "command": "ctest",
                "args": ["--preset", "windows-msys-release-qt-test"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "dependsOn": ["Build: Release"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Test: ASan",
            "type": "shell",
            "osx":   { "command": "ctest", "args": ["--preset", "macos-asan-test-qt"] },
            "linux": { "command": "ctest", "args": ["--preset", "linux-asan-test-qt"] },
            "windows": { "command": "echo", "args": ["ASan not supported on Windows"] },
            "dependsOn": ["Build: ASan"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Static analysis ──────────────────────────────────────────────────
        {
            "label": "Analysis: cppcheck",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-cppcheck"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-cppcheck"] },
            "windows": { "command": "echo", "args": ["cppcheck preset not configured for Windows"] },
            "dependsOn": ["Configure: Checks (clang-tidy + cppcheck, no sanitizer)"],
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Analysis: clang-tidy",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-clang-tidy"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-clang-tidy"] },
            "windows": { "command": "echo", "args": ["clang-tidy preset not configured for Windows"] },
            "dependsOn": ["Configure: Checks (clang-tidy + cppcheck, no sanitizer)"],
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Analysis: All Quality Tools",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-quality-tools"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-quality-tools"] },
            "windows": { "command": "echo", "args": ["Quality tools preset not configured for Windows"] },
            "dependsOn": ["Build: Checks"],
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Format: Check (CI, read-only)",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-format-check"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-format-check"] },
            "windows": { "command": "echo", "args": ["Format check not configured for Windows"] },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Format: Apply in-place",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--build", "--preset", "macos-format"] },
            "linux": { "command": "cmake", "args": ["--build", "--preset", "linux-format"] },
            "windows": { "command": "echo", "args": ["Format not configured for Windows"] },
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Run ──────────────────────────────────────────────────────────────
        {
            "label": "Run: Debug",
            "type": "shell",
            "osx": {
                "command": "${workspaceFolder}/build/macos-debug-qt/src/main/LogViewer.app/Contents/MacOS/LogViewer",
                "args": []
            },
            "linux": {
                "command": "${workspaceFolder}/build/linux-debug-qt/src/main/LogViewer",
                "args": []
            },
            "windows": {
                "command": "${workspaceFolder}/build/windows-debug-qt/src/main/LogViewer.exe",
                "args": [],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "dependsOn": ["Build: Debug"],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Run: Release",
            "type": "shell",
            "osx": {
                "command": "${workspaceFolder}/build/macos-release-qt/src/main/LogViewer.app/Contents/MacOS/LogViewer",
                "args": []
            },
            "linux": {
                "command": "${workspaceFolder}/build/linux-release-qt/src/main/LogViewer",
                "args": []
            },
            "windows": {
                "command": "${workspaceFolder}/build/windows-release-qt/src/main/LogViewer.exe",
                "args": [],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "dependsOn": ["Build: Release"],
            "isBackground": true,
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Package ──────────────────────────────────────────────────────────
        {
            "label": "Package: Release",
            "type": "shell",
            "osx":   { "command": "cpack", "args": ["--preset", "macos-release-package-qt"] },
            "linux": { "command": "cpack", "args": ["--preset", "linux-release-package-qt"] },
            "windows": {
                "command": "cpack",
                "args": ["--preset", "windows-msys-release-qt-package"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "dependsOn": ["Build: Release"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Workflows ────────────────────────────────────────────────────────
        {
            "label": "Workflow: Debug (configure + build + test)",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--workflow", "--preset", "macos-debug-workflow-qt"] },
            "linux": { "command": "cmake", "args": ["--workflow", "--preset", "linux-debug-workflow-qt"] },
            "windows": {
                "command": "cmake",
                "args": ["--workflow", "--preset", "windows-msys-debug-qt-workflow"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Workflow: Release (configure + build + test + package)",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--workflow", "--preset", "macos-release-workflow-qt"] },
            "linux": { "command": "cmake", "args": ["--workflow", "--preset", "linux-release-workflow-qt"] },
            "windows": {
                "command": "cmake",
                "args": ["--workflow", "--preset", "windows-msys-release-qt-workflow"],
                "options": { "env": { "PATH": "C:/msys64/mingw64/bin;$PATH" } }
            },
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Workflow: Quality (configure + build + all tools)",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--workflow", "--preset", "macos-quality-workflow-qt"] },
            "linux": { "command": "cmake", "args": ["--workflow", "--preset", "linux-quality-workflow-qt"] },
            "windows": { "command": "echo", "args": ["Quality workflow not configured for Windows"] },
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Workflow: ASan (configure + build + test)",
            "type": "shell",
            "osx":   { "command": "cmake", "args": ["--workflow", "--preset", "macos-asan-workflow-qt"] },
            "linux": { "command": "cmake", "args": ["--workflow", "--preset", "linux-asan-workflow-qt"] },
            "windows": { "command": "echo", "args": ["ASan not supported on Windows"] },
            "problemMatcher": ["$gcc"],
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Utility ──────────────────────────────────────────────────────────
        {
            "label": "Clean: All build dirs",
            "type": "shell",
            "command": "bash",
            "args": ["-c", "rm -rf '${workspaceFolder}/build'"],
            "problemMatcher": [],
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Clean: Debug",
            "type": "shell",
            "osx":   { "command": "bash", "args": ["-c", "rm -rf '${workspaceFolder}/build/macos-debug-qt'"] },
            "linux": { "command": "bash", "args": ["-c", "rm -rf '${workspaceFolder}/build/linux-debug-qt'"] },
            "windows": { "command": "cmd", "args": ["/c", "rmdir /s /q build\\windows-debug-qt"] },
            "problemMatcher": []
        }
    ]
}
