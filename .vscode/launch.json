{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch QT Debug",
            "type": "cppdbg",
            "request": "launch",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "Build QT Debug",
            "linux": {
                "MIMode": "gdb",
                "program": "${workspaceFolder}/dist/Debug/LogViewerQT"
            },
            "osx": {
                "MIMode": "lldb",
                "program": "${workspaceFolder}/dist/Debug/LogViewerQT.app/Contents/MacOS/LogViewerQT"
            },
            "windows": {
                "MIMode": "gdb",
                "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
                "program": "${workspaceFolder}/dist/Debug/LogViewerQT.exe",
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            }
        },
        {
            "name": "Launch QT Release",
            "type": "cppdbg",
            "request": "launch",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "Build QT Release",
            "linux": {
                "MIMode": "gdb",
                "program": "${workspaceFolder}/dist/Release/LogViewerQT"
            },
            "osx": {
                "MIMode": "lldb",
                "program": "${workspaceFolder}/dist/Release/LogViewerQT.app/Contents/MacOS/LogViewer"
            },
            "windows": {
                "MIMode": "gdb",
                "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
                "program": "${workspaceFolder}/dist/Release/LogViewerQT.exe"
            }
        },
    ],
    "inputs": [
        {
            "id": "gtestFilter",
            "type": "promptString",
            "description": "GTest filter pattern (e.g., XmlParserTest.ParseInvalidXml or XmlParserTest.*)",
            "default": "XmlParserTest.*"
        },
        {
            "id": "logFilePath",
            "type": "promptString",
            "description": "Path to log file to open",
            "default": ""
        }
    ]
}
