{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch QT Debug",
            "type": "cppdbg",
            "request": "launch",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "Build QT Debug",
            "linux": {
                "MIMode": "gdb",
                "program": "${workspaceFolder}/dist/Debug/LogViewerQt"
            },
            "osx": {
                "MIMode": "lldb",
                "program": "${workspaceFolder}/dist/Debug/LogViewerQt.app/Contents/MacOS/LogViewerQt"
            },
            "windows": {
                "MIMode": "gdb",
                "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
                "program": "${workspaceFolder}/dist/Debug/LogViewerQt.exe",
                "environment": [
                    {
                        "name": "PATH",
                        "value": "C:\\msys64\\mingw64\\bin;${env:PATH}"
                    }
                ],
                "setupCommands": [
                    {
                        "description": "Enable pretty-printing for gdb",
                        "text": "-enable-pretty-printing",
                        "ignoreFailures": true
                    }
                ]
            }
        },
