{
    "version": "0.2.0",
    "configurations": [

        // ── macOS ─────────────────────────────────────────────────────────────
        {
            "name": "macOS: Debug (lldb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/macos-debug-qt/src/main/LogViewer.app/Contents/MacOS/LogViewer",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "lldb",
            "preLaunchTask": "Build: Debug",
            "presentation": { "group": "macOS", "order": 1 }
        },
        {
            "name": "macOS: Release (lldb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/macos-release-qt/src/main/LogViewer.app/Contents/MacOS/LogViewer",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "lldb",
            "preLaunchTask": "Build: Release",
            "presentation": { "group": "macOS", "order": 2 }
        },
        {
            "name": "macOS: ASan Debug (lldb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/macos-asan-qt/src/main/LogViewer.app/Contents/MacOS/LogViewer",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "lldb",
            "environment": [
                { "name": "ASAN_OPTIONS",  "value": "detect_leaks=1:halt_on_error=1" },
                { "name": "UBSAN_OPTIONS", "value": "halt_on_error=1:print_stacktrace=1" }
            ],
            "preLaunchTask": "Build: ASan",
            "presentation": { "group": "macOS", "order": 3 }
        },

        // ── Linux ─────────────────────────────────────────────────────────────
        {
            "name": "Linux: Debug (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/linux-debug-qt/src/main/LogViewer",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "preLaunchTask": "Build: Debug",
            "presentation": { "group": "Linux", "order": 1 }
        },
        {
            "name": "Linux: Release (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/linux-release-qt/src/main/LogViewer",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "preLaunchTask": "Build: Release",
            "presentation": { "group": "Linux", "order": 2 }
        },
        {
            "name": "Linux: ASan Debug (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/linux-asan-qt/src/main/LogViewer",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "environment": [
                { "name": "ASAN_OPTIONS",  "value": "detect_leaks=1:halt_on_error=1" },
                { "name": "UBSAN_OPTIONS", "value": "halt_on_error=1:print_stacktrace=1" }
            ],
            "preLaunchTask": "Build: ASan",
            "presentation": { "group": "Linux", "order": 3 }
        },

        // ── Windows ───────────────────────────────────────────────────────────
        {
            "name": "Windows: Debug (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/windows-debug-qt/src/main/LogViewer.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "environment": [{ "name": "PATH", "value": "C:\\msys64\\mingw64\\bin;${env:PATH}" }],
            "setupCommands": [
                { "description": "Enable pretty-printing", "text": "-enable-pretty-printing", "ignoreFailures": true }
            ],
            "preLaunchTask": "Build: Debug",
            "presentation": { "group": "Windows", "order": 1 }
        },
        {
            "name": "Windows: Release (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/windows-release-qt/src/main/LogViewer.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "environment": [{ "name": "PATH", "value": "C:\\msys64\\mingw64\\bin;${env:PATH}" }],
            "setupCommands": [
                { "description": "Enable pretty-printing", "text": "-enable-pretty-printing", "ignoreFailures": true }
            ],
            "preLaunchTask": "Build: Release",
            "presentation": { "group": "Windows", "order": 2 }
        }
    ]
}
