#include <windows.h>

// Application icon
IDI_ICON1 ICON "LogViewer.ico"

// Version information
1 VERSIONINFO
FILEVERSION     0,1,3,0
PRODUCTVERSION  0,1,3,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "LogViewer"
            VALUE "FileDescription",  "LogViewer Application"
            VALUE "FileVersion",      "0.1.3.0"
            VALUE "InternalName",     "LogViewer"
            VALUE "LegalCopyright",   "Copyright (C) 2025"
            VALUE "OriginalFilename", "LogViewer.exe"
            VALUE "ProductName",      "LogViewer"
            VALUE "ProductVersion",   "0.1.3.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

// Application manifest for Windows Common Controls
1 RT_MANIFEST "LogViewer.manifest"