#include <windows.h>

// Application icon
IDI_ICON1 ICON "LogViewer.ico"

// Version information
1 VERSIONINFO
FILEVERSION     @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION  @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Marcin Kwiatkowski"
            VALUE "FileDescription",  "LogViewer — cross-platform log analysis tool"
            VALUE "FileVersion",      "@PROJECT_VERSION@.0"
            VALUE "InternalName",     "LogViewer"
            VALUE "LegalCopyright",   "Copyright (C) 2024-2026 Marcin Kwiatkowski"
            VALUE "OriginalFilename", "LogViewer.exe"
            VALUE "ProductName",      "LogViewer"
            VALUE "ProductVersion",   "@PROJECT_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

// Application manifest for Windows Common Controls
1 RT_MANIFEST "LogViewer.manifest"