@PACKAGE_INIT@

# Generated version file for LogViewer package
set(LogViewer_VERSION "@PACKAGE_VERSION@")

if(PACKAGE_FIND_VERSION)
    if(LogViewer_VERSION VERSION_LESS PACKAGE_FIND_VERSION)
        set(PACKAGE_VERSION_COMPATIBLE FALSE)
    else()
        set(PACKAGE_VERSION_COMPATIBLE TRUE)
    endif()
endif()
