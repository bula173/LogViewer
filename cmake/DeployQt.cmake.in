set(_qt_deploy_tool "@QT_DEPLOY_TOOL@")
set(_qt_deploy_target "@QT_DEPLOY_TARGET@")
set(_qt_install_prefix "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}")
set(_qt_target_path "${_qt_install_prefix}/${_qt_deploy_target}")

if(WIN32)
    file(TO_NATIVE_PATH "${_qt_deploy_tool}" _qt_deploy_tool)
    file(TO_NATIVE_PATH "${_qt_target_path}" _qt_target_path)
    file(TO_NATIVE_PATH "${_qt_install_prefix}" _qt_install_prefix)
endif()

if(NOT EXISTS "${_qt_deploy_tool}")
    message(FATAL_ERROR "Qt deploy tool '${_qt_deploy_tool}' not found")
endif()

if(NOT EXISTS "${_qt_target_path}")
    message(FATAL_ERROR "Qt target '${_qt_target_path}' not found before deployment")
endif()

message(STATUS "Running Qt deploy tool: ${_qt_deploy_tool}")
execute_process(
    COMMAND "${_qt_deploy_tool}"
            @QT_DEPLOY_ARGS@
            "${_qt_target_path}"
    WORKING_DIRECTORY "${_qt_install_prefix}"
    RESULT_VARIABLE _qt_deploy_rv
    OUTPUT_VARIABLE _qt_deploy_stdout
    ERROR_VARIABLE _qt_deploy_stderr)

if(NOT _qt_deploy_rv EQUAL 0)
    message(FATAL_ERROR "Qt deploy tool failed (${_qt_deploy_rv}): ${_qt_deploy_stderr}")
else()
    message(STATUS "Qt deploy output: ${_qt_deploy_stdout}")
endif()
