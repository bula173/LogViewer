    "testPresets": [
        {
            "name": "macos-debug-test-qt",
            "displayName": "macOS Debug Tests",
            "configurePreset": "macos-debug-qt",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "macos-release-test-qt",
            "displayName": "macOS Release Tests",
            "configurePreset": "macos-release-qt",
            "output": { "outputOnFailure": true }
