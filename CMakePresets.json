{
    "version": 6,
    "configurePresets": [
        {
            "name": "macos-debug-qt",
            "displayName": "macOS Debug (Qt)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/macos-debug-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER": "/usr/bin/clang",
                "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
                "CMAKE_PREFIX_PATH": "/opt/homebrew/opt/qt",
                "LibArchive_ROOT": "/opt/homebrew/opt/libarchive",
                "LOGVIEWER_SANITIZER": "Address",
                "ENABLE_CPPCHECK": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-release-qt",
            "displayName": "macOS Release (Qt)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/macos-release-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER": "/usr/bin/clang",
                "CMAKE_CXX_COMPILER": "/usr/bin/clang++",
                "LibArchive_ROOT": "/opt/homebrew/opt/libarchive",
                "CMAKE_PREFIX_PATH": "/opt/homebrew/opt/qt"
                
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "windows-msys-debug-qt",
            "displayName": "Windows MSYS2 Debug (Qt)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-debug-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER": "C:/msys64/mingw64/bin/clang.exe",
                "CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/clang++.exe",
                "CMAKE_MAKE_PROGRAM": "C:/msys64/mingw64/bin/ninja.exe",
                "Qt6_DIR": "C:/msys64/mingw64/lib/cmake/Qt6",
                "ENABLE_CLANG_TIDY": "OFF",
                "LOGVIEWER_SANITIZER": "None"
            },
            "environment": {
                "PATH": "C:/msys64/mingw64/bin;$penv{PATH}"
            }
        },
        {
            "name": "windows-msys-release-qt",
            "displayName": "Windows MSYS2 Release (Qt)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-release-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER": "C:/msys64/mingw64/bin/clang.exe",
                "CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/clang++.exe",
                "CMAKE_MAKE_PROGRAM": "C:/msys64/mingw64/bin/ninja.exe",
                "Qt6_DIR": "C:/msys64/mingw64/lib/cmake/Qt6",
                "ENABLE_CLANG_TIDY": "OFF",
                "LOGVIEWER_SANITIZER": "None"
            },
            "environment": {
                "PATH": "C:/msys64/mingw64/bin;$penv{PATH}"
            }
        },
        {
            "name": "linux-debug-qt",
            "displayName": "Linux Debug (Qt)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/linux-debug-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "Qt6_DIR": "/usr/lib/cmake/Qt6",
                "LOGVIEWER_SANITIZER": "Address",
                "ENABLE_CPPCHECK": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-release-qt",
            "displayName": "Linux Release (Qt)",
