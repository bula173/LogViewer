        {
            "name": "windows-msys-debug-qt-test",
            "displayName": "Windows MSYS2 Debug Tests",
            "configurePreset": "windows-msys-debug-qt",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "windows-msys-release-qt-test",
            "displayName": "Windows MSYS2 Release Tests",
            "configurePreset": "windows-msys-release-qt",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "macos-asan-test-qt",
            "displayName": "macOS ASan Tests",
            "configurePreset": "macos-asan-qt",
            "output": { "outputOnFailure": true },
            "environment": {
                "ASAN_OPTIONS":  "detect_leaks=1:halt_on_error=1",
                "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1"
            }
        },
        {
            "name": "macos-tsan-test-qt",
            "displayName": "macOS TSan Tests",
            "configurePreset": "macos-tsan-qt",
            "output": { "outputOnFailure": true },
            "environment": {
                "TSAN_OPTIONS": "halt_on_error=1"
            }
        },
        {
            "name": "macos-ubsan-test-qt",
            "displayName": "macOS UBSan Tests",
            "configurePreset": "macos-ubsan-qt",
            "output": { "outputOnFailure": true },
            "environment": {
                "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1"
            }
        },
        {
            "name": "linux-asan-test-qt",
            "displayName": "Linux ASan Tests",
            "configurePreset": "linux-asan-qt",
            "output": { "outputOnFailure": true },
            "environment": {
                "ASAN_OPTIONS":  "detect_leaks=1:halt_on_error=1",
                "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1"
            }
        },
        {
            "name": "linux-tsan-test-qt",
            "displayName": "Linux TSan Tests",
            "configurePreset": "linux-tsan-qt",
            "output": { "outputOnFailure": true },
            "environment": {
                "TSAN_OPTIONS": "halt_on_error=1"
            }
        },
        {
            "name": "linux-ubsan-test-qt",
            "displayName": "Linux UBSan Tests",
            "configurePreset": "linux-ubsan-qt",
            "output": { "outputOnFailure": true },
            "environment": {
                "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1"
            }
        }
    ],

