{
    "version": 6,
    "configurePresets": [
        {
            "name": "macos-base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER":             "/usr/bin/clang",
                "CMAKE_CXX_COMPILER":           "/usr/bin/clang++",
                "CMAKE_C_COMPILER_LAUNCHER":    "ccache",
                "CMAKE_CXX_COMPILER_LAUNCHER":  "ccache",
                "CMAKE_PREFIX_PATH":            "/opt/homebrew/opt/qt",
                "LibArchive_ROOT":              "/opt/homebrew/opt/libarchive",
                "CMAKE_MESSAGE_LOG_LEVEL":      "WARNING"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "linux-base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER_LAUNCHER":    "ccache",
                "CMAKE_CXX_COMPILER_LAUNCHER":  "ccache",
                "Qt6_DIR":                      "/usr/lib/cmake/Qt6",
                "CMAKE_MESSAGE_LOG_LEVEL":      "WARNING"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "macos-debug-qt",
            "displayName": "macOS Debug (Qt) [ASan+UBSan]",
            "inherits": "macos-base",
            "binaryDir": "${sourceDir}/build/macos-debug-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "Address",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "macos-release-qt",
            "displayName": "macOS Release (Qt)",
            "inherits": "macos-base",
            "binaryDir": "${sourceDir}/build/macos-release-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Release",
                "LOGVIEWER_SANITIZER": "None",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "macos-asan-qt",
            "displayName": "macOS Debug (Qt) [AddressSanitizer]",
            "inherits": "macos-base",
            "binaryDir": "${sourceDir}/build/macos-asan-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "Address",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "macos-tsan-qt",
            "displayName": "macOS Debug (Qt) [ThreadSanitizer]",
            "inherits": "macos-base",
            "binaryDir": "${sourceDir}/build/macos-tsan-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "Thread",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "macos-ubsan-qt",
            "displayName": "macOS Debug (Qt) [UndefinedBehaviorSanitizer]",
            "inherits": "macos-base",
            "binaryDir": "${sourceDir}/build/macos-ubsan-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "UndefinedBehavior",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "macos-checks-qt",
            "displayName": "macOS Checks (Qt) [cppcheck + clang-tidy, no sanitizer]",
            "inherits": "macos-base",
            "binaryDir": "${sourceDir}/build/macos-checks-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "None",
                "ENABLE_CPPCHECK":    "ON",
                "ENABLE_CLANG_TIDY":  "ON",
                "CLANG_TIDY_FIX":     "OFF"
            }
        },
        {
            "name": "linux-debug-qt",
            "displayName": "Linux Debug (Qt) [ASan+UBSan]",
            "inherits": "linux-base",
            "binaryDir": "${sourceDir}/build/linux-debug-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "Address",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "linux-release-qt",
            "displayName": "Linux Release (Qt)",
            "inherits": "linux-base",
            "binaryDir": "${sourceDir}/build/linux-release-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Release",
                "LOGVIEWER_SANITIZER": "None",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "linux-asan-qt",
            "displayName": "Linux Debug (Qt) [AddressSanitizer]",
            "inherits": "linux-base",
            "binaryDir": "${sourceDir}/build/linux-asan-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "Address",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "linux-tsan-qt",
            "displayName": "Linux Debug (Qt) [ThreadSanitizer]",
            "inherits": "linux-base",
            "binaryDir": "${sourceDir}/build/linux-tsan-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "Thread",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "linux-ubsan-qt",
            "displayName": "Linux Debug (Qt) [UndefinedBehaviorSanitizer]",
            "inherits": "linux-base",
            "binaryDir": "${sourceDir}/build/linux-ubsan-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "UndefinedBehavior",
                "ENABLE_CPPCHECK":    "OFF",
                "ENABLE_CLANG_TIDY":  "OFF"
            }
        },
        {
            "name": "linux-checks-qt",
            "displayName": "Linux Checks (Qt) [cppcheck + clang-tidy, no sanitizer]",
            "inherits": "linux-base",
            "binaryDir": "${sourceDir}/build/linux-checks-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":    "Debug",
                "LOGVIEWER_SANITIZER": "None",
                "ENABLE_CPPCHECK":    "ON",
                "ENABLE_CLANG_TIDY":  "ON",
                "CLANG_TIDY_FIX":     "OFF"
            }
        },
        {
            "name": "windows-msys-debug-qt",
            "displayName": "Windows MSYS2 Debug (Qt)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-debug-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":             "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER":             "C:/msys64/mingw64/bin/clang.exe",
                "CMAKE_CXX_COMPILER":           "C:/msys64/mingw64/bin/clang++.exe",
                "CMAKE_C_COMPILER_LAUNCHER":    "ccache",
                "CMAKE_CXX_COMPILER_LAUNCHER":  "ccache",
                "CMAKE_MAKE_PROGRAM":           "C:/msys64/mingw64/bin/ninja.exe",
                "Qt6_DIR":                      "C:/msys64/mingw64/lib/cmake/Qt6",
                "LOGVIEWER_SANITIZER":          "None",
                "ENABLE_CPPCHECK":             "OFF",
                "ENABLE_CLANG_TIDY":           "OFF",
                "CMAKE_MESSAGE_LOG_LEVEL":      "WARNING"
            },
            "environment": {
                "PATH": "C:/msys64/mingw64/bin;$penv{PATH}"
            }
        },
        {
            "name": "windows-msys-release-qt",
            "displayName": "Windows MSYS2 Release (Qt)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/windows-release-qt",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":             "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER":             "C:/msys64/mingw64/bin/clang.exe",
                "CMAKE_CXX_COMPILER":           "C:/msys64/mingw64/bin/clang++.exe",
                "CMAKE_C_COMPILER_LAUNCHER":    "ccache",
                "CMAKE_CXX_COMPILER_LAUNCHER":  "ccache",
                "CMAKE_MAKE_PROGRAM":           "C:/msys64/mingw64/bin/ninja.exe",
                "Qt6_DIR":                      "C:/msys64/mingw64/lib/cmake/Qt6",
                "LOGVIEWER_SANITIZER":          "None",
                "ENABLE_CPPCHECK":             "OFF",
                "ENABLE_CLANG_TIDY":           "OFF",
                "CMAKE_MESSAGE_LOG_LEVEL":      "WARNING"
            },
            "environment": {
                "PATH": "C:/msys64/mingw64/bin;$penv{PATH}"
            }
        }
    ],

