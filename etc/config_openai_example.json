{
  "default_parser": "xml",
  "logging": {
    "level": "info"
  },
  "filters": {
    "typeFilterField": "level"
  },
  "aiConfig": {
    "provider": "openai",
    "baseUrl": "https://api.openai.com",
    "defaultModel": "gpt-4",
    "apiKey": "sk-your-api-key-here",
    "timeoutSeconds": 60
  },
  "parsers": {
    "xml": {
      "rootElement": "events",
      "eventElement": "event",
      "columns": [
        { "name": "id", "visible":true, "width": 50 },
        { "name": "timestamp", "visible":true, "width": 150 },
        { "name": "level", "visible":true, "width": 200 },
        { "name": "info", "visible":true, "width": 300 }
      ]
    }
  },
  "columnColors": {
    "level": {
      "ERROR":   ["#ffffff", "#ff4200"],
      "WARN":    ["#000000", "#ffcc00"],
      "INFO":    ["#000000", "#90ee90"],
      "DEBUG":   ["#000000", "#d3d3d3"]
    }
  }
}
