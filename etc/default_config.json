{
   "version": {
    "major": 0,
    "minor": 1,
    "patch": 1,
    "type": ""
  },
  "default_parser": "xml",
  "logging": {
    "level": "debug"
  },
  "filters": {
    "typeFilterField": "level"
  },
  "dictionaryFilePath": "etc/field_dictionary.json",
  "aiConfig": {
    "provider": "ollama",
    "baseUrl": "http://localhost:11434",
    "defaultModel": "qwen2.5-coder:7b",
    "timeoutSeconds": 300,
    "_comment": "API keys are stored encrypted. Add them using the UI or manually as plain text (will be encrypted on save)",
    "openaiApiKey": "",
    "anthropicApiKey": "",
    "googleApiKey": "",
    "xaiApiKey": ""
  },
  "parsers": {
    "xml": {
      "rootElement": "events",
      "eventElement": "event",
      "columns": [
        { "name": "id", "visible":true, "width": 50 },
        { "name": "timestamp", "visible":true, "width": 150 },
        { "name": "level", "visible":true, "width": 200 },
        { "name": "info", "visible":true, "width": 300 }
      ]
    }
  },
  "columnColors": {
    "level": {
      "ERROR":   ["#ffffff", "#ff4200"],
      "WARN":    ["#000000", "#ffcc00"],
      "INFO":    ["#000000", "#90ee90"],
      "DEBUG":   ["#000000", "#d3d3d3"]
    }
  }
}