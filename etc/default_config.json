{
   "version": {
    "major": 1,
    "minor": 0,
    "patch": 0,
    "type": ""
  },
  "default_parser": "xml",
  "logging": {
    "level": "debug"
  },
  "filters": {
    "typeFilterField": "level"
  },
  "dictionaryFilePath": "etc/field_dictionary.json",
  "parsers": {
    "xml": {
      "rootElement": "events",
      "eventElement": "event",
      "columns": [
        { "name": "id", "visible":true, "width": 50 },
        { "name": "timestamp", "visible":true, "width": 150 },
        { "name": "level", "visible":true, "width": 200 },
        { "name": "info", "visible":true, "width": 300 }
      ]
    }
  },
  "columnColors": {
    "level": {
      "ERROR":   ["#ffffff", "#ff4200"],
      "WARN":    ["#000000", "#ffcc00"],
      "INFO":    ["#000000", "#90ee90"],
      "DEBUG":   ["#000000", "#d3d3d3"]
    }
  }
}